# For local dev you usually need NOTHING here — the frontend proxies /api/* to
# the backend at BACKEND_URL (see next.config.js), defaulting to localhost:8000.

# Backend location for the server-side proxy (default shown):
BACKEND_URL=http://localhost:8000

# Advanced: bypass the proxy and call the backend directly from the browser
# (requires the backend's CORS to allow this origin):
# NEXT_PUBLIC_API_BASE=http://localhost:8000
