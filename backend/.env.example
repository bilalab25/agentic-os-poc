# Copy to .env and fill in as needed. Every value has a safe default so the
# app runs from a clean clone with NO configuration at all (SQLite + mock LLM
# + sandbox Meta Ads).

# --- Database --------------------------------------------------------------
# Default: SQLite file in the backend dir. For Postgres:
# DATABASE_URL=postgresql+psycopg2://agentic:agentic@localhost:5432/agentic_os
DATABASE_URL=sqlite:///./agentic_os.db

# --- LLM -------------------------------------------------------------------
# LLM_PROVIDER: auto | anthropic | mock   (auto -> Anthropic if a key is set)
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
LLM_MAX_TOKENS=600

# --- Lead qualification ----------------------------------------------------
QUALIFICATION_MIN_SCORE=60

# --- Meta Ads / MCP --------------------------------------------------------
MCP_ENABLED=true
# Leave META_LIVE=false to run in sandbox (no real ad spend possible).
META_LIVE=false
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0

# --- Governance ------------------------------------------------------------
DEFAULT_ACTOR=demo@dezy.local

# --- CORS ------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
