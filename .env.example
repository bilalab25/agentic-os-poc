# Optional root env for `docker compose`. All values have safe defaults; the
# stack runs with NONE of these set (mock LLM + sandbox Meta Ads).
# For real LLM output, set ANTHROPIC_API_KEY.

LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Meta Ads stays in sandbox unless you set META_LIVE=true AND provide creds.
META_LIVE=false
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
